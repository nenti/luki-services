---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import ServiceSection from '../components/ServiceSection.astro';
import Gallery from '../components/Gallery.astro';
import Voice from '../components/Voice.astro';
import Framework from '../components/Framework.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import content from '../content/de.json';
---

<Layout>
  <Header />
  <main>
    <Hero />
    <About />
    <ServiceSection
      id={content.services.wedding.id}
      title={content.services.wedding.title}
      intro={content.services.wedding.intro}
      points={content.services.wedding.points}
      steps={content.services.wedding.steps}
      variant="wedding"
    />
    <ServiceSection
      id={content.services.funeral.id}
      title={content.services.funeral.title}
      intro={content.services.funeral.intro}
      points={content.services.funeral.points}
      steps={content.services.funeral.steps}
      experience={content.services.funeral.experience}
      variant="funeral"
    />
    <Gallery />
    <Voice />
    <Framework />
    <Contact />
  </main>
  <Footer />
</Layout>