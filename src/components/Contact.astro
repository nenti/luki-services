---
import content from '../content/de.json';
const { contact } = content;

const occasionLabels = Object.fromEntries(
  contact.form.occasionOptions.map((opt) => [opt.value, opt.label])
);
---

<section id={contact.id} class="border-t border-sand py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-serif text-3xl text-ink md:text-4xl">{contact.title}</h2>
        <p class="mt-4 text-lg text-ink-muted">{contact.subtitle}</p>
        <div class="mt-8 space-y-3">
          <a
            href={`mailto:${contact.email}`}
            class="block text-lg font-medium text-petrol hover:underline"
          >
            {contact.email}
          </a>
          <a
            href={contact.phoneHref}
            class="block text-lg font-medium text-petrol hover:underline"
          >
            {contact.phone}
          </a>
        </div>
      </div>

      <form
        id="contact-form"
        class="rounded-2xl border border-sand bg-white p-6 shadow-sm md:p-8"
        novalidate
      >
        <input type="hidden" name="access_key" value="fce4cefa-3271-474f-a7a8-8cf59d24a20b" />
        <input type="checkbox" name="botcheck" class="hidden" style="display: none" tabindex="-1" autocomplete="off" />

        <div id="contact-form-fields" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-ink">{contact.form.name}</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1.5 w-full rounded-lg border border-sand bg-cream px-4 py-2.5 text-ink outline-none focus:border-petrol focus:ring-1 focus:ring-petrol"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-ink">{contact.form.email}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1.5 w-full rounded-lg border border-sand bg-cream px-4 py-2.5 text-ink outline-none focus:border-petrol focus:ring-1 focus:ring-petrol"
            />
          </div>
          <div>
            <label for="occasion" class="block text-sm font-medium text-ink">{contact.form.occasion}</label>
            <select
              id="occasion"
              name="occasion"
              class="mt-1.5 w-full rounded-lg border border-sand bg-cream px-4 py-2.5 text-ink outline-none focus:border-petrol focus:ring-1 focus:ring-petrol"
            >
              {contact.form.occasionOptions.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </select>
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="date" class="block text-sm font-medium text-ink">{contact.form.date}</label>
              <input
                type="text"
                id="date"
                name="date"
                class="mt-1.5 w-full rounded-lg border border-sand bg-cream px-4 py-2.5 text-ink outline-none focus:border-petrol focus:ring-1 focus:ring-petrol"
              />
            </div>
            <div>
              <label for="location" class="block text-sm font-medium text-ink">{contact.form.location}</label>
              <input
                type="text"
                id="location"
                name="location"
                class="mt-1.5 w-full rounded-lg border border-sand bg-cream px-4 py-2.5 text-ink outline-none focus:border-petrol focus:ring-1 focus:ring-petrol"
              />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-ink">{contact.form.message}</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="mt-1.5 w-full rounded-lg border border-sand bg-cream px-4 py-2.5 text-ink outline-none focus:border-petrol focus:ring-1 focus:ring-petrol"
            ></textarea>
          </div>
        </div>

        <p
          id="contact-form-status"
          class="mt-4 hidden rounded-lg px-4 py-3 text-sm"
          role="status"
          aria-live="polite"
        ></p>

        <button
          id="contact-form-submit"
          type="submit"
          class="mt-6 w-full rounded-full bg-petrol px-8 py-3.5 font-medium text-cream transition-colors hover:bg-petrol-light disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
        >
          {contact.form.submit}
        </button>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ occasionLabels, formCopy: contact.form }}>
  const form = document.getElementById('contact-form');
  const fields = document.getElementById('contact-form-fields');
  const status = document.getElementById('contact-form-status');
  const submitBtn = document.getElementById('contact-form-submit');

  function showStatus(message, type) {
    if (!status) return;
    status.textContent = message;
    status.classList.remove('hidden', 'bg-cream', 'text-ink-muted', 'bg-red-50', 'text-red-800', 'border', 'border-red-200');
    if (type === 'success') {
      status.classList.add('bg-cream', 'text-ink-muted');
    } else {
      status.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    const data = new FormData(form);
    const occasion = occasionLabels[data.get('occasion')] || data.get('occasion');
    const date = data.get('date') || '–';
    const location = data.get('location') || '–';

    submitBtn.disabled = true;
    submitBtn.textContent = formCopy.submitting;
    status?.classList.add('hidden');

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify({
          access_key: data.get('access_key'),
          name: data.get('name'),
          email: data.get('email'),
          subject: `Anfrage: ${occasion}`,
          message: data.get('message'),
          Anlass: occasion,
          Wunschtermin: date,
          Ort: location,
          botcheck: data.get('botcheck'),
        }),
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        throw new Error(result.message || 'submit failed');
      }

      form.reset();
      fields?.classList.add('hidden');
      submitBtn.classList.add('hidden');
      showStatus(formCopy.success, 'success');
    } catch {
      showStatus(formCopy.error, 'error');
      submitBtn.disabled = false;
      submitBtn.textContent = formCopy.submit;
    }
  });
</script>