---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';

interface Section {
  heading: string;
  content: string;
}

interface Props {
  title: string;
  sections: Section[];
}

const { title, sections } = Astro.props;
---

<Layout title={`${title} — Dr. Lukas Hetzelein`}>
  <Header />
  <main class="mx-auto max-w-3xl px-6 pt-32 pb-20">
    <h1 class="font-serif text-4xl text-ink">{title}</h1>
    <div class="mt-10 space-y-10">
      {sections.map((section) => (
        <section>
          <h2 class="text-lg font-medium text-ink">{section.heading}</h2>
          <p class="mt-3 whitespace-pre-line leading-relaxed text-ink-muted">{section.content}</p>
        </section>
      ))}
    </div>
    <a href="/" class="mt-12 inline-block text-sm font-medium text-petrol hover:underline">
      ← Zurück zur Startseite
    </a>
  </main>
  <Footer />
</Layout>