---
import content from '../content/de.json';
const { hero } = content;
---

<section class="relative overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 lg:grid-cols-2">
    <div class="order-2 lg:order-1">
      <p class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-accent">
        {hero.eyebrow}
      </p>
      <h1 class="font-serif text-4xl leading-tight text-ink md:text-5xl lg:text-6xl">
        {hero.title}
      </h1>
      <p class="mt-6 max-w-lg text-lg leading-relaxed text-ink-muted">
        {hero.subtitle}
      </p>
      <a
        href="#kontakt"
        class="mt-8 inline-flex rounded-full bg-petrol px-8 py-3.5 text-base font-medium text-cream transition-colors hover:bg-petrol-light"
      >
        {hero.cta}
      </a>
    </div>
    <div class="order-1 lg:order-2">
      <div class="relative mx-auto aspect-[4/5] max-w-md overflow-hidden rounded-2xl bg-sand shadow-xl shadow-petrol/10">
        <img
          src={hero.image}
          alt={hero.imageAlt}
          class="h-full w-full object-cover object-center"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink/20 to-transparent"></div>
      </div>
    </div>
  </div>
</section>